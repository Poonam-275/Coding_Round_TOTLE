generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
  VIEWER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  displayName String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  campaigns Campaign[]
}

model Campaign {
  id          String     @id @default(cuid())
  name        String
  message     String
  scheduledAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdById String
  createdBy   User       @relation(fields: [createdById], references: [id])
  recipients  Recipient[]
  messages    Message[]
  replies     Reply[]
}

model Recipient {
  id          String   @id @default(cuid())
  phone       String
  name        String?
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  REPLIED
  FAILED
}

model Message {
  id          String        @id @default(cuid())
  campaignId  String
  campaign    Campaign      @relation(fields: [campaignId], references: [id])
  recipientId String
  recipient   Recipient     @relation(fields: [recipientId], references: [id])
  status      MessageStatus @default(QUEUED)
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  repliedAt   DateTime?
  error       String?
}

model Reply {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id])
  content    String
  createdAt  DateTime @default(now())
}
